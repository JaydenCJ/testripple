{
  "name": "testripple",
  "version": "0.1.0",
  "description": "Computes which tests a git diff can affect via static import-graph analysis.",
  "author": "JaydenCJ <aisingioro.kiyon@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "testripple": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"tests/*.test.mjs\"",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "test-impact-analysis",
    "affected-tests",
    "import-graph",
    "git-diff",
    "monorepo",
    "ci",
    "test-selection"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/testripple.git"
  },
  "homepage": "https://github.com/JaydenCJ/testripple#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/testripple/issues"
  }
}
